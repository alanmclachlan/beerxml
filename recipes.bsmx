<F_R_STYLE><_MOD_>2011-06-12</_MOD_>
<F_S_NAME>Blonde Ale</F_S_NAME>
<F_S_CATEGORY>Light Hybrid Beer</F_S_CATEGORY>
<F_S_GUIDE>BJCP 2008</F_S_GUIDE>
<F_S_LETTER>2</F_S_LETTER>
