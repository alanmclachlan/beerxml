<F_R_STYLE><_MOD_>2014-07-06</_MOD_>
<F_S_NAME>Premium American Lager</F_S_NAME>
<F_S_CATEGORY>Light Lager</F_S_CATEGORY>
<F_S_GUIDE>BJCP 2008</F_S_GUIDE>
<F_S_LETTER>3</F_S_LETTER>
<F_S_NUMBER>1</F_S_NUMBER>
<F_S_TYPE>1</F_S_TYPE>
